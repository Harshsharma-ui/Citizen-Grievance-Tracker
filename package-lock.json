import React, { useEffect, useState } from 'react';
import { Complaint, isDemoMode } from '../../lib/supabase';
import { updateComplaintStatus, getComplaints } from '../../lib/actions';
import { motion, AnimatePresence } from 'motion/react';
import { Filter, Clock, CheckCircle, AlertCircle, ChevronRight, User, Loader2, X, FileText } from 'lucide-react';
import { cn } from '../../lib/utils';
import { formatDistanceToNow } from 'date-fns';
import { supabase } from '../../lib/supabase';

export default function OfficerDashboard() {
  const [complaints, setComplaints] = useState<Complaint[]>([]);
  const [loading, setLoading] = useState(true);
  const [selectedComplaint, setSelectedComplaint] = useState<Complaint | null>(null);

  const fetchComplaints = async () => {
    try {
      const data = await getComplaints();
      setComplaints(data);
    } catch (err) {
      console.error('Failed to fetch complaints', err);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchComplaints();

    if (isDemoMode) {
      // Poll in demo mode
      const interval = setInterval(fetchComplaints, 5000);
      return () => clearInterval(interval);
    } else {
      // Real-time subscription in production
      const channel = supabase
        .channel('complaints_changes')
        .on('postgres_changes' as any, { event: '*', table: 'complaints' }, () => {
          fetchComplaints();
        })
        .subscribe();

      return () => {
        supabase.removeChannel(channel);
      };
    }
  }, []);

  const handleStatusChange = async (id: string, status: any) => {
    try {
      await updateComplaintStatus(id, status);
      setSelectedComplaint(null);
      fetchComplaints();
    } catch (err) {
      console.error(err);
    }
  };

  return (
    <div className="max-w-5xl mx-auto p-4 md:p-12 space-y-10 transition-colors duration-300">
      <header className="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <div className="flex items-center space-x-2 mb-2">
            <div className="w-2 h-2 bg-indigo-600 rounded-full animate-pulse" />
            <span className="text-[10px] font-black uppercase tracking-[0.2em] text-indigo-600">Departmental Access</span>
          </div>
          <h1 className="text-4xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tighter uppercase leading-none">
            Officer <span className="text-indigo-600">Portal</span>
          </h1>
          <p className="text-slate-500 dark:text-slate-400 font-medium mt-2">Municipal Grievance Management System v2.0</p>
        </div>
        <div className="flex items-center space-x-4">
          <div className="bg-white dark:bg-slate-900 border-2 border-slate-100 dark:border-slate-800 px-6 py-3 rounded-2xl flex items-center space-x-3 shadow-sm transition-colors">
            <div className="w-10 h-10 bg-slate-900 dark:bg-slate-800 rounded-xl flex items-center justify-center text-white">
              <User size={20} />
            </div>
            <div>
              <p className="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Officer ID</p>
              <p className="font-bold text-slate-900 dark:text-white">#MUM-442-B</p>
            </div>
          </div>
        </div>
      </header>

      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div className="bg-white dark:bg-slate-900 p-8 rounded-[32px] border-2 border-slate-50 dark:border-slate-800 shadow-xl shadow-slate-100 dark:shadow-none group hover:border-indigo-100 dark:hover:border-indigo-900 transition-all">
          <div className="w-12 h-12 bg-slate-50 dark:bg-slate-800 rounded-2xl flex items-center justify-center text-slate-400 dark:text-slate-500 mb-4 group-hover:bg-indigo-50 dark:group-hover:bg-indigo-900/30 group-hover:text-indigo-600 transition-colors">
            <AlertCircle size={24} />
          </div>
          <p className="text-slate-400 dark:text-slate-500 text-[10px] font-black uppercase tracking-widest">Pending Action</p>
          <p className="text-4xl font-black text-slate-900 dark:text-white mt-1">{complaints.filter(c => c.status === 'ASSIGNED').length}</p>
        </div>
        <div className="bg-white dark:bg-slate-900 p-8 rounded-[32px] border-2 border-slate-50 dark:border-slate-800 shadow-xl shadow-slate-100 dark:shadow-none group hover:border-indigo-100 dark:hover:border-indigo-900 transition-all">
          <div className="w-12 h-12 bg-indigo-50 dark:bg-indigo-900/30 rounded-2xl flex items-center justify-center text-indigo-600 mb-4">
            <Clock size={24} />
          </div>
          <p className="text-slate-400 dark:text-slate-500 text-[10px] font-black uppercase tracking-widest">In Progress</p>
          <p className="text-4xl font-black text-indigo-600 mt-1">{complaints.filter(c => c.status === 'IN_PROGRESS').length}</p>
        </div>
        <div className="bg-white dark:bg-slate-900 p-8 rounded-[32px] border-2 border-slate-50 dark:border-slate-800 shadow-xl shadow-slate-100 dark:shadow-none group hover:border-emerald-100 dark:hover:border-emerald-900 transition-all">
          <div className="w-12 h-12 bg-emerald-50 dark:bg-emerald-900/30 rounded-2xl flex items-center justify-center text-emerald-600 mb-4">
            <CheckCircle size={24} />
          </div>
          <p className="text-slate-400 dark:text-slate-500 text-[10px] font-black uppercase tracking-widest">Resolved</p>
          <p className="text-4xl font-black text-emerald-600 mt-1">{complaints.filter(c => c.status === 'RESOLVED').length}</p>
        </div>
      </div>

      <div className="space-y-6">
        <div className="flex items-center justify-between border-b-2 border-slate-100 dark:border-slate-800 pb-4 transition-colors">
          <h2 className="text-xl font-black text-slate-900 dark:text-white uppercase tracking-tight flex items-center space-x-3">
            <Filter size={20} className="text-indigo-600" />
            <span>Active Grievances</span>
          </h2>
          <div className="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">
            Showing {complaints.length} Records
          </div>
        </div>

        <div className="grid grid-cols-1 gap-4">
          {loading ? (
            <div className="p-20 text-center flex flex-col items-center space-y-4">
              <Loader2 className="animate-spin text-indigo-600" size={40} />
              <p className="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Synchronizing Database...</p>
            </div>
          ) : complaints.length === 0 ? (
            <div className="p-20 text-center bg-slate-50 dark:bg-slate-900/50 rounded-[32px] border-4 border-dashed border-slate-100 dark:border-slate-800 transition-colors">
              <div className="w-16 h-16 bg-white dark:bg-slate-800 rounded-3xl flex items-center justify-center text-slate-200 dark:text-slate-700 mx-auto mb-4 shadow-sm">
                <FileText size={32} />
              </div>
              <p className="text-sm font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">No grievances assigned to your department.</p>
            </div>
          ) : (
            complaints.map((c, idx) => (
              <motion.div
                key={c.id}
                initial={{ opacity: 0, y: 10 }}
                animate={{ opacity: 1, y: 0 }}
                transition={{ delay: idx * 0.05 }}
                onClick={() => setSelectedComplaint(c)}
                className="bg-white dark:bg-slate-900 p-4 md:p-6 rounded-[24px] border-2 border-slate-50 dark:border-slate-800 shadow-lg shadow-slate-100 dark:shadow-none hover:shadow-xl hover:border-indigo-100 dark:hover:border-indigo-900 transition-all cursor-pointer flex flex-col md:flex-row md:items-center justify-between group gap-4"
              >
                <div className="flex items-start md:items-center space-x-4 md:space-x-6 w-full">
                  <div className={cn(
                    "w-12 h-12 md:w-16 md:h-16 shrink-0 rounded-2xl flex items-center justify-center overflow-hidden shadow-inner border-2 border-white dark:border-slate-700",
                    c.status === 'RESOLVED' ? "bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600" : 
                    c.status === 'IN_PROGRESS' ? "bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600" : "bg-amber-50 dark:bg-amber-900/30 text-amber-600"
                  )}>
                    {c.status === 'RESOLVED' ? <CheckCircle size={24} className="md:w-7 md:h-7" /> : 
                     c.status === 'IN_PROGRESS' ? <Clock size={24} className="md:w-7 md:h-7" /> : <AlertCircle size={24} className="md:w-7 md:h-7" />}
                  </div>
                  <div className="flex-1 min-w-0">
                    <div className="flex flex-wrap items-center gap-2 mb-1">
                      <span className={cn(
                        "text-[8px] font-black uppercase tracking-widest px-2 py-0.5 rounded-full shrink-0",
                        c.severity === 'high' ? "bg-red-100 dark:bg-red-900/30 text-red-600" : "bg-amber-100 dark:bg-amber-900/30 text-amber-600"
                      )}>
                        {c.severity} Priority
                      </span>
                      <span className="text-[8px] font-black text-slate-300 dark:text-slate-600 uppercase tracking-widest shrink-0">
                        {formatDistanceToNow(new Date(c.created_at))} ago
                      </span>
                    </div>
                    <h3 className="text-base md:text-lg font-black text-slate-900 dark:text-white uppercase tracking-tight truncate">{c.category}</h3>
                    <p className="text-xs md:text-sm text-slate-500 dark:text-slate-400 font-medium line-clamp-1 md:max-w-md">{c.description}</p>
                  </div>
                </div>
                <div className="flex items-center justify-between md:justify-end w-full md:w-auto mt-2 md:mt-0">
                  <div className={cn(
                    "px-3 py-1.5 md:px-4 md:py-2 rounded-xl text-[10px] font-black uppercase tracking-widest border-2",
                    c.status === 'RESOLVED' ? "border-emerald-100 dark:border-emerald-900 bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600" : 
                    c.status === 'IN_PROGRESS' ? "border-indigo-100 dark:border-indigo-900 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600" : "border-amber-100 dark:border-amber-900 bg-amber-50 dark:bg-amber-900/30 text-amber-600"
                  )}>
                    {c.status.replace('_', ' ')}
                  </div>
                  <ChevronRight className="text-slate-200 dark:text-slate-700 group-hover:text-indigo-600 group-hover:translate-x-1 transition-all" />
                </div>
              </motion.div>
            ))
          )}
        </div>
      </div>

      {/* Mobile Bottom Sheet for Status Update */}
      <AnimatePresence>
        {selectedComplaint && (
          <>
            <motion.div 
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              onClick={() => setSelectedComplaint(null)}
              className="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[2000]"
            />
            <motion.div
              initial={{ y: '100%' }}
              animate={{ y: 0 }}
              exit={{ y: '100%' }}
              transition={{ type: 'spring', damping: 30, stiffness: 300 }}
              className="fixed bottom-0 left-0 right-0 bg-white dark:bg-slate-900 rounded-t-[48px] p-6 md:p-10 z-[2001] shadow-2xl max-w-2xl mx-auto border-t-4 border-indigo-600 transition-colors max-h-[90vh] overflow-y-auto"
            >
              <div className="w-16 h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full mx-auto mb-8" />
              <div className="space-y-6 md:space-y-8">
                <div className="flex items-start justify-between">
                  <div>
                    <div className="flex items-center space-x-2 mb-2">
                      <span className={cn(
                        "px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest",
                        selectedComplaint.severity === 'high' ? "bg-red-100 dark:bg-red-900/30 text-red-600" : "bg-amber-100 dark:bg-amber-900/30 text-amber-600"
                      )}>
                        {selectedComplaint.severity} Priority
                      </span>
                      <span className="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Case #{selectedComplaint.id.slice(0, 8)}</span>
                    </div>
                    <h3 className="text-2xl md:text-3xl font-black text-slate-900 dark:text-white uppercase tracking-tighter leading-none">{selectedComplaint.category}</h3>
                  </div>
                  <button onClick={() => setSelectedComplaint(null)} className="p-2 bg-slate-50 dark:bg-slate-800 rounded-full text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors shrink-0 ml-4">
                    <X size={24} />
                  </button>
                </div>

                <div className="grid grid-cols-1 gap-6">
                  <div className="space-y-4">
                    <p className="text-sm font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Description</p>
                    <p className="text-slate-600 dark:text-slate-300 font-medium leading-relaxed">{selectedComplaint.description}</p>
                    <div className="pt-4 space-y-2">
                      <p className="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Location Coordinates</p>
                      <div className="bg-slate-50 dark:bg-slate-800 p-3 rounded-xl font-mono text-xs text-slate-500 dark:text-slate-400 border border-slate-100 dark:border-slate-700">
                        {selectedComplaint.latitude.toFixed(6)}, {selectedComplaint.longitude.toFixed(6)}
                      </div>
                    </div>
                  </div>
                </div>

                <div className="space-y-4 pt-4">
                  <p className="text-sm font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest text-center">Update Operational Status</p>
                  <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <button 
                      onClick={() => handleStatusChange(selectedComplaint.id, 'IN_PROGRESS')}
                      className="py-5 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 rounded-2xl font-black uppercase tracking-widest text-xs hover:bg-indigo-100 dark:hover:bg-indigo-900/50 transition-all active:scale-95 border-2 border-indigo-100 dark:border-indigo-900"
                    >
                      In Progress
                    </button>
                    <button 
                      onClick={() => handleStatusChange(selectedComplaint.id, 'RESOLVED')}
                      className="py-5 bg-emerald-500 text-white rounded-2xl font-black uppercase tracking-widest text-xs shadow-xl shadow-emerald-200 dark:shadow-none hover:bg-emerald-600 transition-all active:scale-95"
                    >
                      Resolve Case
                    </button>
                    <button 
                      onClick={() => handleStatusChange(selectedComplaint.id, 'REJECTED')}
                      className="py-5 bg-slate-50 dark:bg-slate-800 text-slate-400 dark:text-slate-500 rounded-2xl font-black uppercase tracking-widest text-xs hover:bg-red-50 dark:hover:bg-red-900/30 hover:text-red-600 dark:hover:text-red-400 transition-all active:scale-95 border-2 border-slate-100 dark:border-slate-700 hover:border-red-100 dark:hover:border-red-900"
                    >
                      Reject
                    </button>
                  </div>
                </div>
              </div>
            </motion.div>
          </>
        )}
      </AnimatePresence>
    </div>
  );
}
